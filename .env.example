RENTFLEX_WEB_PORT=5184
RENTFLEX_API_PORT=5185
VITE_API_PROXY_TARGET=http://127.0.0.1:5185
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/rentflex
DATABASE_SSL=false
ALLOW_DEMO_SEED=true
PUBLIC_APP_URL=http://localhost:5184
APP_BASE_URL=http://localhost:5184
LAUNCH_CHECK_SECRET=replace_with_long_random_secret

APP_NAME=RentFlex Ledger

# Public (safe in browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional compatibility aliases
VITE_CLERK_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Private backend-only variables
CLERK_SECRET_KEY=sk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
OPENAI_API_KEY=sk_replace_me
SENDGRID_API_KEY=SG_replace_me
RESEND_API_KEY=re_replace_me
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me

BYPASS_AUTH=false
REQUIRE_CLERK_STRIPE_ENV=true
